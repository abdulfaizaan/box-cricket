generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String   @id @default(uuid()) @db.Uuid
  email          String   @unique
  passwordHash   String
  whatsappNumber String?
  whatsappApiKey String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PricingRule {
  id         String   @id @default(uuid()) @db.Uuid
  startTime  String   // e.g., "08:00"
  endTime    String   // e.g., "20:00"
  hourlyRate Decimal  @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
}

model Booking {
  id           String    @id @default(uuid()) @db.Uuid
  playerName   String    @db.VarChar(100)
  playerPhone  String    @db.VarChar(15)
  playerEmail  String    @db.VarChar(255)
  bookingDate  DateTime  @db.Date
  startTime    String    // e.g., "08:00"
  endTime      String    // e.g., "09:00"
  totalPrice   Decimal   @db.Decimal(10, 2)
  otpCode      String    @db.VarChar(6)
  status       String    @default("PENDING") // PENDING, VERIFIED, EXPIRED, CANCELLED
  isVerified   Boolean   @default(false)
  isOffline    Boolean   @default(false)
  verifiedAt   DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz

  @@unique([bookingDate, startTime])
  @@index([bookingDate, startTime])
  @@index([otpCode])
}
