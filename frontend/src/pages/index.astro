---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="min-h-screen bg-[#f4f4f0] font-sans selection:bg-[#ccff00] selection:text-black">
    <!-- Hero Section -->
    <header class="bg-black text-white py-16 md:py-24 px-4 md:px-6 text-center relative border-b-8 border-black overflow-hidden">
      <div class="relative z-10 max-w-5xl mx-auto">
        <div class="inline-block bg-[#ccff00] text-black font-black uppercase tracking-widest text-xs md:text-sm px-3 md:px-4 py-1 border-2 border-black mb-6 transform -rotate-2">
          Box Cricket Booking
        </div>
        <h1 class="text-5xl sm:text-6xl md:text-8xl font-black mb-4 md:mb-6 tracking-tighter uppercase leading-none">PitchPass</h1>
        <p class="text-xl sm:text-2xl md:text-3xl mb-8 md:mb-12 font-bold max-w-3xl mx-auto leading-tight px-4">Book. Verify. Play. No Nonsense.</p>
        <a href="/book" class="inline-block bg-[#ccff00] text-black font-black uppercase text-lg md:text-xl px-8 md:px-12 py-4 md:py-5 border-4 border-black shadow-[6px_6px_0px_rgba(255,255,255,1)] md:shadow-[8px_8px_0px_rgba(255,255,255,1)] hover:shadow-[2px_2px_0px_rgba(255,255,255,1)] hover:translate-x-[4px] hover:translate-y-[4px] md:hover:translate-x-[6px] md:hover:translate-y-[6px] transition-all duration-150">
          Book a Slot Now
        </a>
      </div>
      
      <!-- Decorative background elements -->
      <div class="absolute top-10 left-10 w-24 h-24 bg-white border-4 border-black opacity-20 transform rotate-12"></div>
      <div class="absolute bottom-10 right-10 w-32 h-32 rounded-full border-8 border-[#ccff00] opacity-40"></div>
    </header>

    <!-- Pricing Section -->
    <section class="max-w-6xl mx-auto py-16 md:py-24 px-4 md:px-6 border-x-0 md:border-x-8 border-black bg-white">
      <h2 class="text-4xl md:text-5xl font-black text-center mb-12 md:mb-16 uppercase tracking-tight text-black border-b-8 border-black inline-block pb-2">Pricing</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
        <!-- Day Card -->
        <div class="bg-white border-4 border-black p-6 md:p-10 text-center shadow-[8px_8px_0px_rgba(0,0,0,1)] md:shadow-[12px_12px_0px_rgba(0,0,0,1)] hover:shadow-[4px_4px_0px_rgba(0,0,0,1)] hover:translate-x-[4px] hover:translate-y-[4px] md:hover:translate-x-[8px] md:hover:translate-y-[8px] transition-all duration-150 group">
          <div class="w-16 h-16 md:w-20 md:h-20 bg-[#ccff00] border-4 border-black rounded-full flex items-center justify-center mx-auto mb-6 md:mb-8 group-hover:rotate-12 transition-transform">
            <svg class="w-8 h-8 md:w-10 md:h-10 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="3" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          </div>
          <h3 class="text-3xl md:text-4xl font-black text-black mb-2 uppercase">Day Rate</h3>
          <p class="text-black font-bold text-lg md:text-xl mb-4 md:mb-6 bg-[#f4f4f0] border-2 border-black inline-block px-3 md:px-4 py-1 transform -rotate-1">08:00 AM - 08:00 PM</p>
          <p class="text-5xl md:text-6xl font-black text-black">₹500<span class="text-xl md:text-2xl font-bold">/HR</span></p>
        </div>
        
        <!-- Night Card -->
        <div class="bg-black border-4 border-black p-6 md:p-10 text-center text-white shadow-[8px_8px_0px_rgba(204,255,0,1)] md:shadow-[12px_12px_0px_rgba(204,255,0,1)] hover:shadow-[4px_4px_0px_rgba(204,255,0,1)] hover:translate-x-[4px] hover:translate-y-[4px] md:hover:translate-x-[8px] md:hover:translate-y-[8px] transition-all duration-150 group relative overflow-hidden">
          <div class="w-16 h-16 md:w-20 md:h-20 bg-white border-4 border-black rounded-full flex items-center justify-center mx-auto mb-6 md:mb-8 group-hover:-rotate-12 transition-transform relative z-10">
            <svg class="w-8 h-8 md:w-10 md:h-10 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="3" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
          </div>
          <h3 class="text-3xl md:text-4xl font-black mb-2 uppercase relative z-10 text-[#ccff00]">Night Rate</h3>
          <p class="text-black font-bold text-lg md:text-xl mb-4 md:mb-6 bg-white border-2 border-white inline-block px-3 md:px-4 py-1 transform rotate-1 relative z-10">08:00 PM - 08:00 AM</p>
          <p class="text-5xl md:text-6xl font-black relative z-10 text-white">₹700<span class="text-xl md:text-2xl font-bold text-gray-400">/HR</span></p>
        </div>
      </div>
    </section>

    <!-- Info Section -->
    <section class="bg-[#ccff00] py-16 md:py-24 px-4 md:px-6 border-y-8 border-black relative">
      <!-- Decorative brutalist pattern -->
      <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(black 2px, transparent 2px); background-size: 20px 20px;"></div>
      
      <div class="max-w-6xl mx-auto text-center relative z-10">
        <h2 class="text-4xl md:text-5xl font-black mb-16 md:mb-20 text-black uppercase tracking-tight bg-white border-4 border-black inline-block px-6 md:px-8 py-2 md:py-3 shadow-[6px_6px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_rgba(0,0,0,1)] transform -rotate-1">How It Works</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-10">
          <div class="bg-white border-4 border-black p-6 md:p-8 shadow-[6px_6px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_rgba(0,0,0,1)] relative mt-4 md:mt-0">
            <div class="bg-black text-[#ccff00] w-14 h-14 md:w-16 md:h-16 border-4 border-black flex items-center justify-center mb-6 text-3xl md:text-4xl font-black transform -translate-y-12 -translate-x-10 md:-translate-x-12 absolute shadow-[4px_4px_0px_rgba(0,0,0,0.2)]">1</div>
            <h4 class="font-black text-xl md:text-2xl text-black uppercase mb-3 md:mb-4 mt-4 md:mt-2">Pick Slots</h4>
            <p class="text-black font-bold text-base md:text-lg leading-relaxed">Choose your date and aggressively smash the slots you want to book.</p>
          </div>
          <div class="bg-white border-4 border-black p-6 md:p-8 shadow-[6px_6px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_rgba(0,0,0,1)] relative mt-8 md:mt-0">
            <div class="bg-black text-[#ccff00] w-14 h-14 md:w-16 md:h-16 border-4 border-black flex items-center justify-center mb-6 text-3xl md:text-4xl font-black transform -translate-y-12 -translate-x-10 md:-translate-x-12 absolute shadow-[4px_4px_0px_rgba(0,0,0,0.2)]">2</div>
            <h4 class="font-black text-xl md:text-2xl text-black uppercase mb-3 md:mb-4 mt-4 md:mt-2">Get OTP</h4>
            <p class="text-black font-bold text-base md:text-lg leading-relaxed">Drop your details to receive a 6-digit access code instantly.</p>
          </div>
          <div class="bg-white border-4 border-black p-6 md:p-8 shadow-[6px_6px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_rgba(0,0,0,1)] relative mt-8 md:mt-0">
            <div class="bg-black text-[#ccff00] w-14 h-14 md:w-16 md:h-16 border-4 border-black flex items-center justify-center mb-6 text-3xl md:text-4xl font-black transform -translate-y-12 -translate-x-10 md:-translate-x-12 absolute shadow-[4px_4px_0px_rgba(0,0,0,0.2)]">3</div>
            <h4 class="font-black text-xl md:text-2xl text-black uppercase mb-3 md:mb-4 mt-4 md:mt-2">Pay & Play</h4>
            <p class="text-black font-bold text-base md:text-lg leading-relaxed">Flash your code at the venue, pay up offline, and get on the pitch.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-black border-t-8 border-black py-12 px-6 text-center text-white">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
        <p class="font-bold text-lg">&copy; {new Date().getFullYear()} PITCHPASS.</p>
        <a href="/host-xyz-secret" class="bg-[#ccff00] text-black font-black uppercase px-6 py-2 border-2 border-black shadow-[4px_4px_0px_rgba(255,255,255,1)] hover:shadow-[1px_1px_0px_rgba(255,255,255,1)] hover:translate-x-[3px] hover:translate-y-[3px] transition-all">Host Login &rarr;</a>
      </div>
    </footer>
  </main>
</Layout>
